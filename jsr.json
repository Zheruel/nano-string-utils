{
  "name": "@zheruel/nano-string-utils",
  "version": "0.28.1",
  "description": "Ultra-lightweight string utilities with zero dependencies. Tree-shakeable (<1KB each), TypeScript-first, type-safe. Validation, XSS prevention, case conversion, fuzzy matching & more.",
  "keywords": [
    "string",
    "string-utils",
    "string-manipulation",
    "text-processing",
    "utilities",
    "zero-dependencies",
    "tree-shakeable",
    "typescript",
    "type-safe",
    "validation",
    "email-validation",
    "sanitization",
    "xss-prevention",
    "case-conversion",
    "camelcase",
    "kebab-case",
    "slugify",
    "fuzzy-match",
    "levenshtein",
    "pluralize",
    "unicode",
    "lodash-alternative",
    "es-toolkit",
    "deno",
    "bun",
    "lightweight"
  ],
  "exports": "./src/index.ts",
  "publish": {
    "include": ["src/**/*.ts", "README.md", "LICENSE", "CHANGELOG.md"],
    "exclude": [
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/*.config.ts",
      "benchmarks/**",
      "tests/**",
      "docs/**",
      ".github/**",
      ".claude/**",
      "node_modules/**",
      "dist/**",
      "*.md",
      "!README.md",
      "!CHANGELOG.md"
    ]
  }
}
